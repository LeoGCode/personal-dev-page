{
  "name": "personal-dev-page",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash -c 'source scripts/ports.sh --env && docker compose --profile dev up dev'",
    "dev:build": "bash -c 'source scripts/ports.sh --env && docker compose --profile dev up --build dev'",
    "dev:down": "docker compose --profile dev --profile full down",
    "dev:logs": "docker compose --profile dev logs -f",
    "dev:local": "bash -c 'source scripts/ports.sh --env && next dev'",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "checks": "node --experimental-strip-types scripts/run_checks.ts",
    "e2e": "bash -c 'source scripts/ports.sh --print && playwright test'",
    "e2e:desktop": "bash -c 'source scripts/ports.sh && playwright test --project=desktop-chrome'",
    "e2e:mobile": "bash -c 'source scripts/ports.sh && playwright test --project=mobile-iphone --project=mobile-android'",
    "e2e:ui": "bash -c 'source scripts/ports.sh && playwright test --ui'",
    "e2e:video": "bash -c 'source scripts/ports.sh && RECORD_VIDEO=true playwright test'",
    "e2e:showcase": "bash -c 'source scripts/ports.sh --print && RECORD_VIDEO=true playwright test --project=showcase'",
    "e2e:odoo": "bash -c 'source scripts/ports.sh --print && playwright test --project=odoo-crm'",
    "e2e:odoo:video": "bash -c 'source scripts/ports.sh --print && RECORD_VIDEO=true playwright test --project=odoo-crm'",
    "e2e:report": "playwright show-report",
    "odoo:up": "bash -c 'source scripts/ports.sh --print && docker compose --profile odoo up -d odoo'",
    "odoo:down": "docker compose --profile odoo stop odoo odoo-db",
    "odoo:init": "bash -c 'source scripts/ports.sh --env && node --experimental-strip-types scripts/odoo-init.ts'",
    "odoo:logs": "docker compose --profile odoo logs -f odoo",
    "postbuild": "next-sitemap",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@mdx-js/mdx": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@next/mdx": "16.2.1",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/components": "^1.0.11",
    "@sentry/nextjs": "10.46.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "gray-matter": "4.0.3",
    "lucide-react": "1.7.0",
    "motion": "12.38.0",
    "next": "16.2.1",
    "next-intl": "4.8.3",
    "next-sitemap": "4.2.3",
    "posthog-js": "^1.364.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.0",
    "reading-time": "1.5.0",
    "rehype-pretty-code": "0.14.3",
    "resend": "6.9.4",
    "shiki": "4.0.2",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-onboarding": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/nextjs-vite": "^10.3.4",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdx": "2.0.13",
    "@types/node": "25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.1",
    "eslint-plugin-storybook": "^10.3.4",
    "jsdom": "^29.0.1",
    "nodemailer": "^8.0.4",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "storybook": "^10.3.4",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.2"
  }
}
