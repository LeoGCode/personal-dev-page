# ──────────────────────────────────────────────────────────────
# personal-dev-page environment configuration
# ──────────────────────────────────────────────────────────────
# Copy to .env and fill in secrets. `pnpm run dev` auto-generates
# .env.local with the correct mapped ports.
#
# For Vercel deployment, set the relevant variables in the Vercel
# dashboard instead. See docs/deployment.md for the full guide.
# ──────────────────────────────────────────────────────────────

# ── Site URL ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Odoo CRM (optional — leave empty to skip CRM integration) ──
ODOO_URL=http://localhost:8069
ODOO_DB=nexora
ODOO_USER=admin
ODOO_PASSWORD=admin
ODOO_PERSONAL_TEAM_ID=
ODOO_MASTER_PASSWORD=admin

# ── Email (Resend — leave empty for local Mailpit) ───────────
RESEND_API_KEY=
EMAIL_FROM=Leonel <hello@leoneldev.com>
# Where to send lead notifications (your email). Leave empty to disable.
NOTIFICATION_EMAIL=hello@leoneldev.com

# ── Rate limiting ────────────────────────────────────────────
# On Vercel/serverless: set Upstash Redis credentials for durable
# rate limiting across invocations. Get free credentials at upstash.com.
# On self-hosted: leave empty to use in-memory rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Max form submissions per IP per hour (default: 3)
# RATE_LIMIT_MAX=3

# ── PostHog Analytics ────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ── Sentry ───────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Build configuration ──────────────────────────────────────
# Set to "true" for Docker standalone builds (set automatically
# in the Dockerfile). Vercel does not need this.
# STANDALONE=true

# ── Port overrides (optional, local dev only) ────────────────
# Set these to force specific ports. Leave unset to auto-discover.
# APP_PORT=3000
# MAILPIT_UI_PORT=8025
# MAILPIT_SMTP_PORT=1025
# ODOO_PORT=8069
# ODOO_DB_PORT=5434
