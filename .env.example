# ──────────────────────────────────────────────────────────────
# personal-dev-page environment configuration
# ──────────────────────────────────────────────────────────────
# Copy to .env and fill in secrets. Docker services use internal
# hostnames (postgres:5432, redis:6379) automatically.
# For host-side tools (drizzle-kit, etc.), `npm run dev` auto-
# generates .env.local with the correct mapped ports.
# ──────────────────────────────────────────────────────────────

# Database (used by host-side tooling; Docker overrides internally)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/personal_site

# Odoo CRM
ODOO_URL=http://localhost:8069
ODOO_DB=nexora
ODOO_USER=admin
ODOO_PASSWORD=admin
ODOO_PERSONAL_TEAM_ID=

# Redis (used by host-side tooling; Docker overrides internally)
REDIS_URL=redis://localhost:6380

# Email (Resend — leave empty for local Mailpit)
RESEND_API_KEY=
EMAIL_FROM=Leonel <hello@leoneldev.com>
# Where to send lead notifications (your email). Leave empty to disable.
NOTIFICATION_EMAIL=hello@leoneldev.com

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Odoo master password (for database management API)
ODOO_MASTER_PASSWORD=admin

# ── Port overrides (optional) ────────────────────────────────
# Set these to force specific ports. Leave unset to auto-discover.
# APP_PORT=3000
# POSTGRES_PORT=5433
# REDIS_PORT=6380
# MAILPIT_UI_PORT=8025
# MAILPIT_SMTP_PORT=1025
# ODOO_PORT=8069
# ODOO_DB_PORT=5434
